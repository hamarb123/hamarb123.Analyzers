<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>

		<PackageId>hamarb123.Analyzers</PackageId>
		<Copyright>Copyright © Hamish Arblaster 2022-2026</Copyright>
		<Company>hamarb123 FunBandit29</Company>
		<Description>Custom roslyn analyzers by hamarb123 to improve code.</Description>
		<ProjectGuid>{F9B28023-EA29-4E26-9419-327CFAD3426F}</ProjectGuid>
		<PackageVersion>1.3.7</PackageVersion>
		<PackageProjectUrl>https://github.com/hamarb123/hamarb123.Analyzers</PackageProjectUrl>
		<RepositoryUrl>https://github.com/hamarb123/hamarb123.Analyzers</RepositoryUrl>
		<Description>hamarb123.Analyzers</Description>
		<PackageTags>hamarb123.Analyzers, analyzers</PackageTags>
		<DevelopmentDependency>true</DevelopmentDependency>
		<NoPackageAnalysis>true</NoPackageAnalysis>

		<TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_AddAnalyzersToOutput</TargetsForTfmSpecificContentInPackage>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\hamarb123.Analyzers\hamarb123.Analyzers.4.12.0.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers\hamarb123.Analyzers.4.9.2.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers\hamarb123.Analyzers.4.8.0.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers\hamarb123.Analyzers.4.7.0.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers\hamarb123.Analyzers.4.3.1.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers.CS\hamarb123.Analyzers.CS.4.12.0.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers.CS\hamarb123.Analyzers.CS.4.9.2.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers.CS\hamarb123.Analyzers.CS.4.8.0.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers.CS\hamarb123.Analyzers.CS.4.7.0.csproj" />
		<ProjectReference Include="..\hamarb123.Analyzers.CS\hamarb123.Analyzers.CS.4.3.1.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Update="tools\*.ps1" CopyToOutputDirectory="PreserveNewest" Pack="true" PackagePath="" />
		<None Include="..\.editorconfig" Link=".editorconfig" />
		<None Include="hamarb123.Analyzers.targets" Pack="true" PackagePath="buildTransitive\" />
		<None Include="hamarb123.Analyzers.targets" Pack="true" PackagePath="build\" />
	</ItemGroup>

	<Target Name="_AddAnalyzersToOutput">
		<ItemGroup>
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.12.0.dll" PackagePath="analyzers/dotnet/roslyn4.12.0/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.CS.4.12.0.dll" PackagePath="analyzers/dotnet/roslyn4.12.0/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.12.0.dll" PackagePath="analyzers/dotnet/roslyn4.12.0/vb" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.9.2.dll" PackagePath="analyzers/dotnet/roslyn4.9.2/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.CS.4.9.2.dll" PackagePath="analyzers/dotnet/roslyn4.9.2/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.9.2.dll" PackagePath="analyzers/dotnet/roslyn4.9.2/vb" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.8.0.dll" PackagePath="analyzers/dotnet/roslyn4.8.0/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.CS.4.8.0.dll" PackagePath="analyzers/dotnet/roslyn4.8.0/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.8.0.dll" PackagePath="analyzers/dotnet/roslyn4.8.0/vb" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.7.0.dll" PackagePath="analyzers/dotnet/roslyn4.7.0/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.CS.4.7.0.dll" PackagePath="analyzers/dotnet/roslyn4.7.0/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.7.0.dll" PackagePath="analyzers/dotnet/roslyn4.7.0/vb" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.3.1.dll" PackagePath="analyzers/dotnet/roslyn4.3.1/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.CS.4.3.1.dll" PackagePath="analyzers/dotnet/roslyn4.3.1/cs" />
			<TfmSpecificPackageFile Include="$(OutputPath)\hamarb123.Analyzers.4.3.1.dll" PackagePath="analyzers/dotnet/roslyn4.3.1/vb" />
		</ItemGroup>
	</Target>

</Project>
